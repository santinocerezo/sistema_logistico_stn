# ============================================================
# STN PQ's — Variables de Entorno
# Copiar este archivo a .env y completar los valores reales
# ============================================================

# --- Aplicación ---
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# --- Base de Datos (PostgreSQL) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stnpq
POSTGRES_USER=stnpq_user
POSTGRES_PASSWORD=stnpq_pass
DATABASE_URL=postgresql://stnpq_user:stnpq_pass@localhost:5432/stnpq

# --- Cache (Redis) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass
REDIS_URL=redis://:redis_pass@localhost:6379

# --- Almacenamiento (MinIO / S3) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=minio_secret
MINIO_BUCKET_EVIDENCES=evidences
MINIO_BUCKET_AVATARS=avatars
MINIO_USE_SSL=false

# --- JWT ---
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Encriptación AES-256-GCM ---
# Clave maestra de 32 bytes en hex (64 caracteres hex)
ENCRYPTION_MASTER_KEY=change_me_32_byte_hex_key_here_0000000000000000000000000000000000

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# --- Pasarela de Pago ---
PAYMENT_GATEWAY_API_KEY=your_payment_gateway_api_key
PAYMENT_GATEWAY_SECRET=your_payment_gateway_secret
PAYMENT_GATEWAY_URL=https://api.payment-gateway.com

# --- Email (SendGrid / AWS SES) ---
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@stnpqs.com
EMAIL_FROM_NAME=STN PQ's

# --- SMS (Twilio / AWS SNS) ---
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# --- Web Push (VAPID) ---
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@stnpqs.com

# --- Agente IA (OpenAI / Anthropic) ---
AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o
AI_TIMEOUT_MS=90000

# --- Rate Limiting ---
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW_MS=60000
RATE_LIMIT_LOGIN_BLOCK_MS=900000
RATE_LIMIT_API_MAX=100
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_QUOTE_MAX=10
RATE_LIMIT_QUOTE_WINDOW_MS=3600000

# --- GPS / Rastreo ---
GPS_UPDATE_INTERVAL_MS=30000
GPS_AVG_SPEED_KMH=30
GPS_MAX_DELIVERY_FAIL_DISTANCE_KM=0.2
